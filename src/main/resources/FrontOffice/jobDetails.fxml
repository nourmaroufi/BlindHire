<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.FrontOffice.JobDetailsController"
      spacing="0"
      style="-fx-background-color: linear-gradient(to bottom, #f8fafc, #f1f5f9);">

    <!-- HEADER WITH GRADIENT BACKGROUND -->
    <StackPane style="-fx-background-color: linear-gradient(to right, #0c4a6e, #057995);
                       -fx-padding: 30 40;">
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Button text="← go back"
                    onAction="#handleBack"
                    style="-fx-background-color: rgba(255,255,255,0.2);
                           -fx-text-fill: white;
                           -fx-font-size: 20px;
                           -fx-font-weight: bold;
                           -fx-min-width: 40;
                           -fx-min-height: 40;
                           -fx-max-width: 40;
                           -fx-max-height: 40;
                           -fx-background-radius: 20;
                           -fx-cursor: hand;
                           -fx-border-color: rgba(255,255,255,0.3);
                           -fx-border-radius: 20;"
                    onMouseEntered="#handleBackHover"
                    onMouseExited="#handleBackExit"/>

            <VBox spacing="5">
                <Label text="Job Details"
                       style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                <Label text="Comprehensive overview"
                       style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.5);"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- COMPANY LOGO PLACEHOLDER -->
            <Circle radius="25" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.3)" strokeWidth="2">
                <StackPane.margin>
                    <Insets right="10"/>
                </StackPane.margin>
            </Circle>
        </HBox>
    </StackPane>

    <!-- MAIN CONTENT AREA WITH SCROLL -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-width: 0;">

        <VBox spacing="25" style="-fx-padding: 30 40; -fx-background-color: transparent;">

            <!-- JOB TITLE CARD -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25;
                                      -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10,0,0,3);">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <StackPane style="-fx-background-color: #e0f7fd; -fx-padding: 15; -fx-background-radius: 15;">
                        <Label text="💼" style="-fx-font-size: 30px;"/>
                    </StackPane>

                    <VBox spacing="8">
                        <Label fx:id="titleLabel"
                               style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0f172a;
                                      -fx-font-family: 'Segoe UI Semibold';"/>

                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Circle fx:id="statusIndicator" radius="6" fill="#10b981"/>
                            <Label fx:id="statusLabel"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- QUICK INFO GRID -->
            <GridPane hgap="20" vgap="15" style="-fx-background-color: white; -fx-padding: 25;
                                                   -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10,0,0,3);">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <!-- Job Type -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="JOB TYPE" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: #e0f7fd; -fx-padding: 8; -fx-background-radius: 10;">
                            <Label text="🕒" style="-fx-font-size: 16px;"/>
                        </StackPane>
                        <Label fx:id="typeLabel"
                               style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #0f172a;"/>
                    </HBox>
                </VBox>

                <!-- Posted Date -->
                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="POSTED DATE" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: #f1f5f9; -fx-padding: 8; -fx-background-radius: 10;">
                            <Label text="📅" style="-fx-font-size: 16px;"/>
                        </StackPane>
                        <Label fx:id="dateLabel"
                               style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #0f172a;"/>
                    </HBox>
                </VBox>

                <!-- Location (placeholder - add if you have this field) -->
                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="LOCATION" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: #fee2e2; -fx-padding: 8; -fx-background-radius: 10;">
                            <Label text="📍" style="-fx-font-size: 16px;"/>
                        </StackPane>
                        <Label text="Remote / Hybrid"
                               style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #0f172a;"/>
                    </HBox>
                </VBox>

                <!-- Salary (dynamic) -->
                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="SALARY" style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <StackPane style="-fx-background-color: #dcfce7; -fx-padding: 8; -fx-background-radius: 10;">
                            <Label text="💰" style="-fx-font-size: 16px;"/>
                        </StackPane>
                        <Label fx:id="salaryLabel"
                               style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #059669;"/>
                    </HBox>
                </VBox>
            </GridPane>

            <!-- JOB DESCRIPTION SECTION -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25;
                                      -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10,0,0,3);">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="4" height="25" fill="#0fafdd" style="-fx-arc-width: 2; -fx-arc-height: 2;"/>
                    <Label text="Job Description"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                </HBox>

                <Label fx:id="descriptionLabel"
                       wrapText="true"
                       style="-fx-font-size: 15px; -fx-text-fill: #334155; -fx-line-spacing: 5;"/>
            </VBox>

            <!-- REQUIRED SKILLS SECTION -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25;
                                      -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10,0,0,3);">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="4" height="25" fill="#e11d48" style="-fx-arc-width: 2; -fx-arc-height: 2;"/>
                    <Label text="Required Skills"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                </HBox>

                <FlowPane fx:id="skillsContainer" hgap="10" vgap="10">
                    <!-- Skills will be added dynamically -->
                </FlowPane>
            </VBox>

            <!-- AI MATCH SECTION -->
            <VBox spacing="15"
                  style="-fx-background-color: white; -fx-padding: 25;
             -fx-background-radius: 20;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10,0,0,3);">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="4" height="25" fill="#22c55e"
                               style="-fx-arc-width: 2; -fx-arc-height: 2;"/>
                    <Label text="Compatibility Score"
                           style="-fx-font-size: 20px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #0f172a;"/>
                </HBox>

                <Label fx:id="matchPercentageLabel"
                       text="Calculating..."
                       style="-fx-font-size: 18px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #22c55e;"/>

                <ProgressBar fx:id="matchProgressBar"
                             prefWidth="600"
                             progress="0.0"
                             style="-fx-accent: #22c55e;"/>

            </VBox>

            <!-- ACTION BUTTONS -->
            <HBox spacing="15" alignment="CENTER">
                <Button text="Apply Now"
                        onAction="#handleApply"
                        style="-fx-background-color: linear-gradient(to right, #0fafdd, #057995);
                               -fx-text-fill: white;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;
                               -fx-padding: 15 40;
                               -fx-background-radius: 30;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(15,175,221,0.25), 15,0,0,5);"
                        onMouseEntered="#handleApplyHover"
                        onMouseExited="#handleApplyExit"/>

                <Button text="Save for Later"
                        onAction="#handleSave"
                        style="-fx-background-color: white;
                               -fx-text-fill: #0fafdd;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;
                               -fx-padding: 15 40;
                               -fx-background-radius: 30;
                               -fx-border-color: #0fafdd;
                               -fx-border-width: 2;
                               -fx-border-radius: 30;
                               -fx-cursor: hand;"
                        onMouseEntered="#handleSaveHover"
                        onMouseExited="#handleSaveExit"/>
            </HBox>

            <!-- SIMILAR JOBS SECTION (optional) -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25;
                                      -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10,0,0,3);">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="4" height="25" fill="#8b5cf6" style="-fx-arc-width: 2; -fx-arc-height: 2;"/>
                    <Label text="Similar Jobs"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                </HBox>

                <HBox fx:id="similarJobsContainer" spacing="15">
                    <!-- Similar jobs will be added dynamically -->
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>