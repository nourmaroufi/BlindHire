<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            prefHeight="900.0"
            prefWidth="1400.0"
            minHeight="700.0"
            minWidth="1200.0"
            style="-fx-background-color: linear-gradient(to bottom right, #e8f5f3, #d5edf4, #e2eef8);">

    <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

    <!-- ═══════════════════════  SIDEBAR  ═══════════════════════════════════ -->
    <left>
        <VBox spacing="0"
              prefWidth="250"
              style="-fx-background-color: rgba(255,255,255,0.95);
                     -fx-border-color: transparent rgba(0,0,0,0.07) transparent transparent;
                     -fx-border-width: 0 1 0 0;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.09), 18, 0, 4, 0);">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 26 20 20 20;">
                <Rectangle width="36" height="36" arcWidth="12" arcHeight="12"
                           style="-fx-fill: linear-gradient(to bottom right, #14b8a6, #0891b2);"/>
                <VBox spacing="1">
                    <Label text="BlindHire"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-family: Segoe UI;"/>
                    <Label text="RH Agency"
                           style="-fx-font-size: 10px; -fx-text-fill: #94a3b8; -fx-font-family: Segoe UI;"/>
                </VBox>
            </HBox>

            <!-- Divider -->
            <Region prefHeight="1" maxHeight="1"
                    style="-fx-background-color: #e2e8f0;"/>

            <!-- Nav -->
            <VBox spacing="4" style="-fx-padding: 18 12 10 12;">
                <Label text="NAVIGATION"
                       style="-fx-font-size: 9px; -fx-font-weight: bold;
                              -fx-text-fill: #94a3b8; -fx-padding: 0 6 8 6;"/>

                <Button text="🏠  Home"
                        onAction="#loadDashboard"
                        style="-fx-background-color: #0d9488; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-font-family: Segoe UI;
                               -fx-alignment: CENTER_LEFT; -fx-background-radius: 12;
                               -fx-padding: 12 16; -fx-cursor: hand; -fx-border-width: 0;
                               -fx-effect: dropshadow(gaussian, rgba(13,148,136,0.35),10,0,0,3);"
                        maxWidth="Infinity"/>

                <Button text="💼  Jobs"
                        onAction="#handleJobs"
                        style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                               -fx-font-size: 13px; -fx-font-family: Segoe UI;
                               -fx-alignment: CENTER_LEFT; -fx-background-radius: 12;
                               -fx-padding: 12 16; -fx-cursor: hand; -fx-border-width: 0;"
                        maxWidth="Infinity"/>

                <Button text="🏢  Companies"
                        style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                               -fx-font-size: 13px; -fx-font-family: Segoe UI;
                               -fx-alignment: CENTER_LEFT; -fx-background-radius: 12;
                               -fx-padding: 12 16; -fx-cursor: hand; -fx-border-width: 0;"
                        maxWidth="Infinity"/>

                <Button text="📊  Dashboard"
                        style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                               -fx-font-size: 13px; -fx-font-family: Segoe UI;
                               -fx-alignment: CENTER_LEFT; -fx-background-radius: 12;
                               -fx-padding: 12 16; -fx-cursor: hand; -fx-border-width: 0;"
                        maxWidth="Infinity"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Sign In / Sign Up -->
            <VBox spacing="8" alignment="CENTER"
                  style="-fx-padding: 14 16;
                         -fx-border-color: #e2e8f0 transparent transparent transparent;
                         -fx-border-width: 1 0 0 0;">
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Sign In" onAction="#handleSignIn"
                            style="-fx-background-color: transparent; -fx-text-fill: #0d9488;
                                   -fx-font-weight: bold; -fx-font-size: 13px;
                                   -fx-cursor: hand; -fx-border-color: #0d9488;
                                   -fx-border-radius: 20; -fx-padding: 8 18;
                                   -fx-background-radius: 20;"/>
                    <Button text="Sign Up" onAction="#handleSignUp"
                            style="-fx-background-color: linear-gradient(to right, #0d9488, #0891b2);
                                   -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-font-size: 13px; -fx-background-radius: 20;
                                   -fx-padding: 8 18; -fx-cursor: hand; -fx-border-width: 0;"/>
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- ═══════════════════════  CONTENT AREA  ══════════════════════════════ -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: transparent;"/>
    </center>

</BorderPane>
