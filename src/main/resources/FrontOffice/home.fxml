<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.Color?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.FrontOffice.HomeController"
            prefHeight="900.0"
            prefWidth="1400.0"
            minHeight="700.0"
            minWidth="1200.0"
            style="-fx-background-color: linear-gradient(to bottom right, #f8fafc, #f1f5f9);">

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>



            <!-- ========== SIDEBAR ========== -->
            <left>

            <VBox spacing="30"
                  prefWidth="280"
                  style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 3); -fx-padding: 30 20;"
                  HBox.hgrow="NEVER">

                <!-- Logo -->
                <HBox alignment="CENTER" spacing="12" style="-fx-cursor: hand; -fx-padding: 0 0 20 0;">
                    <Rectangle width="45" height="45" arcWidth="15" arcHeight="15"
                               style="-fx-fill: linear-gradient(to bottom right, #4f46e5, #3b82f6);"/>
                    <Label text="BlindHire"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                </HBox>

                <Separator style="-fx-background-color: #e2e8f0;"/>

                <!-- User Profile Card -->
                <VBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0 20 0;">
                    <Circle radius="50" fill="linear-gradient(to bottom right, #4f46e5, #3b82f6)">
                        <effect>
                            <DropShadow color="#4f46e540" radius="15" spread="0.2"/>
                        </effect>
                    </Circle>
                    <Label text="Guest User"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label text="Not signed in"
                           style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    <HBox spacing="10" alignment="CENTER">
                        <Button text="Sign In" onAction="#handleSignIn"
                                style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-radius: 20; -fx-padding: 8 20;"/>
                        <Button text="Sign Up" onAction="#handleSignUp"
                                style="-fx-background-color: linear-gradient(to right, #4f46e5, #3b82f6); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <Separator style="-fx-background-color: #e2e8f0;"/>

                <!-- Main Navigation -->
                <VBox spacing="5">
                    <Label text="MAIN MENU"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-padding: 10 15;"/>

                    <Button text="🏠 Home"
                            onAction="#loadDashboard"
                            style="-fx-background-color: #f1f5f9; -fx-text-fill: #3b82f6; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 15 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>

                    <Button text="💼 Jobs"
                            onAction="#handleJobs"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 16px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 15 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>

                    <Button text="🏢 Companies"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 16px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 15 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>

                    <Button text="📊 Dashboard"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 16px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 15 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>
                </VBox>

                <Separator style="-fx-background-color: #e2e8f0;"/>

                <!-- Categories -->
                <VBox spacing="5">
                    <Label text="CATEGORIES"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-padding: 10 15;"/>

                    <Button text="💻 Technology"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 15px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 12 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>

                    <Button text="🎨 Design"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 15px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 12 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>

                    <Button text="📊 Marketing"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 15px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 12 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>

                    <Button text="💰 Finance"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 15px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 12 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>

                    <Button text="⚙️ Engineering"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 15px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 12 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Bottom Menu -->
                <VBox spacing="5">
                    <Separator style="-fx-background-color: #e2e8f0;"/>

                    <Button text="⚙️ Settings"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 15px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 12 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>

                    <Button text="❓ Help"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 15px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 12 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>

                    <Button text="🚪 Logout"
                            style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-font-size: 15px; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 12 20; -fx-border: none; -fx-alignment: CENTER_LEFT;"/>
                </VBox>

                <!-- Version Info -->
                <Label text="Version 1.0.0"
                       style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-alignment: CENTER; -fx-padding: 10 0 0 0;"/>
            </VBox>
            </left>
    <!-- Dynamic Content Area -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #f5f7fa;"/>
    </center>



</BorderPane>