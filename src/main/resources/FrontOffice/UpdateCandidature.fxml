<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.FrontOffice.UpdateCandidatureController"
      spacing="20"
      style="-fx-padding: 25; -fx-background-color: white;">

    <Label text="Update Application"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="15" vgap="15">

        <!-- Expected Salary -->
        <Label text="Expected Salary:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="salaryField"
                   GridPane.rowIndex="0"
                   GridPane.columnIndex="1"/>

        <!-- Cover Letter -->
        <Label text="Cover Letter:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextArea fx:id="coverLetterArea"
                  prefRowCount="4"
                  GridPane.rowIndex="1"
                  GridPane.columnIndex="1"/>

        <!-- CV Path -->
        <Label text="CV Path:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="cvPathField"
                   GridPane.rowIndex="2"
                   GridPane.columnIndex="1"/>

    </GridPane>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel"/>
        <Button text="Save Changes"
                style="-fx-background-color:#4f46e5; -fx-text-fill:white;"
                onAction="#handleSave"/>
    </HBox>

</VBox>