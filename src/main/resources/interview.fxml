<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controller.InterviewPageController"
      spacing="20"
      stylesheets="@style.css"
      styleClass="root">


    <!-- Padding for the main VBox -->
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- ================= HEADER ================= -->
    <HBox alignment="CENTER_LEFT" styleClass="header-banner">
        <Label text="Interviews Dashboard" styleClass="header-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Schedule an Interview"
                onAction="#openAddInterviewForm"
                style="-fx-background-color: white;
                   -fx-text-fill: #1a2980;
                   -fx-background-radius: 20;"/>
    </HBox>


    <!-- ================= TAB PANE ================= -->
    <TabPane fx:id="mainTabPane"
             tabClosingPolicy="UNAVAILABLE"
             prefHeight="600"
             VBox.vgrow="ALWAYS">
        <VBox.margin>
            <Insets top="25"/>
        </VBox.margin>


        <!-- ========== DASHBOARD TAB ========== -->
        <Tab text="Dashboard">

            <VBox spacing="10">
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label text="Filter by type:"
                           style="-fx-font-weight: bold;"/>

                    <ComboBox fx:id="filterTypeComboBox"
                              prefWidth="150"/>
                </HBox>
                <!-- Header -->
                <HBox spacing="10"
                      style="-fx-background-color: #e3eaf2;
                     -fx-padding: 12;
                     -fx-background-radius: 10;">


                    <Label text="Candidate"
                           prefWidth="100"
                           style="-fx-font-weight: bold;" />

                    <Label text="Interview Date"
                           prefWidth="160"
                           style="-fx-font-weight: bold;" />

                    <Label text="Type"
                           prefWidth="120"
                           style="-fx-font-weight: bold;" />

                    <Label text="Job Offer"
                           prefWidth="120"
                           style="-fx-font-weight: bold;" />

                    <Label text="Interviewer"
                           prefWidth="120"
                           style="-fx-font-weight: bold;" />

                    <Label text="Actions"
                           prefWidth="160"
                           style="-fx-font-weight: bold;" />

                </HBox>

                <!-- Scrollable Interviews -->
                <ScrollPane fitToWidth="true"
                            style="-fx-background-color: transparent;">

                    <VBox fx:id="interviewContainer"
                          spacing="10">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>
                    </VBox>

                </ScrollPane>

            </VBox>

        </Tab>


        <!-- ========== CALENDAR TAB ========== -->
        <Tab text="Calendar">

            <VBox alignment="CENTER" spacing="20">

                <VBox fx:id="calendarContainer"
                      styleClass="calendar-wrapper"
                      prefWidth="900"
                      prefHeight="600"/>

            </VBox>

        </Tab>


    </TabPane>

</VBox>
