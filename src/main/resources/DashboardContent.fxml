<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox spacing="30"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml">

    <!-- Greeting -->
    <Label text="Good Morning, Sandy!"
           style="-fx-font-size: 28px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #1a2980;"/>

    <!-- ================= CARDS ================= -->
    <HBox spacing="25">

        <VBox spacing="10"
              prefWidth="260"
              style="-fx-background-color: #dbeafe;
                     -fx-background-radius: 20;
                     -fx-padding: 25;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0.2, 0, 4);">
            <children>
                <Label text="Team Stats"
                       style="-fx-font-weight: bold; -fx-font-size: 16;"/>
                <Label text="2019 - 2022"/>
                <Button text="Details"
                        style="-fx-background-color: white;
                               -fx-background-radius: 15;"/>
            </children>
        </VBox>

        <VBox spacing="10"
              prefWidth="260"
              style="-fx-background-color: #fbcfe8;
                     -fx-background-radius: 20;
                     -fx-padding: 25;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0.2, 0, 4);">
            <children>
                <Label text="Ideation Workshop"
                       style="-fx-font-weight: bold; -fx-font-size: 16;"/>
                <Label text="View Proposals"/>
                <Button text="Details"
                        style="-fx-background-color: white;
                               -fx-background-radius: 15;"/>
            </children>
        </VBox>

        <VBox spacing="10"
              prefWidth="260"
              style="-fx-background-color: #fef9c3;
                     -fx-background-radius: 20;
                     -fx-padding: 25;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0.2, 0, 4);">
            <children>
                <Label text="Upcoming Training"
                       style="-fx-font-weight: bold; -fx-font-size: 16;"/>
                <Label text="July 2022"/>
                <Button text="Details"
                        style="-fx-background-color: white;
                               -fx-background-radius: 15;"/>
            </children>
        </VBox>

    </HBox>

</VBox>