<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controller.FrontOffice.PracticeInterviewController"
      spacing="0"
      style="-fx-background-color: #f0f6fc;">

    <!-- ═══════════════════════  HEADER BANNER  ═══════════════════════════ -->
    <VBox spacing="0"
          style="-fx-background-color: linear-gradient(to right, #0c4a6e, #0284c7, #0fafdd);
                 -fx-effect: dropshadow(gaussian, rgba(2,132,199,0.30), 16, 0, 0, 6);">

        <!-- Nav row -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-padding: 14 24 0 24;">
            <Button text="← Back"
                    onAction="#handleBack"
                    style="-fx-background-color: rgba(255,255,255,0.15);
                           -fx-text-fill: white;
                           -fx-border-color: rgba(255,255,255,0.35);
                           -fx-border-radius: 20; -fx-background-radius: 20;
                           -fx-padding: 7 18; -fx-font-size: 12px;
                           -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Live indicator -->
            <HBox spacing="6" alignment="CENTER"
                  style="-fx-background-color: rgba(255,255,255,0.12);
                         -fx-background-radius: 20; -fx-padding: 5 14;">
                <Label text="●"
                       style="-fx-text-fill: #4ade80; -fx-font-size: 10px;"/>
                <Label text="AI LIVE"
                       style="-fx-text-fill: white; -fx-font-size: 11px;
                              -fx-font-weight: bold;"/>
            </HBox>
        </HBox>

        <!-- Title area -->
        <VBox alignment="CENTER" spacing="6"
              style="-fx-padding: 18 24 24 24;">
            <Label text="🎤  AI Interview Practice"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;
                          -fx-text-fill: white;
                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.20), 4, 0, 0, 2);"/>
            <Label text="Sharpen your skills with a real-time AI-powered mock interview"
                   style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.75);"/>

            <!-- Step pills -->
            <HBox spacing="8" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                <HBox spacing="6" alignment="CENTER"
                      style="-fx-background-color: rgba(255,255,255,0.20);
                             -fx-background-radius: 20; -fx-padding: 5 14;">
                    <Label text="1" style="-fx-background-color: white;
                                          -fx-text-fill: #0c4a6e;
                                          -fx-background-radius: 50;
                                          -fx-min-width: 20; -fx-min-height: 20;
                                          -fx-alignment: center;
                                          -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label text="Enter job title"
                           style="-fx-text-fill: white; -fx-font-size: 12px;"/>
                </HBox>
                <Label text="›" style="-fx-text-fill: rgba(255,255,255,0.50); -fx-font-size: 14px;"/>
                <HBox spacing="6" alignment="CENTER"
                      style="-fx-background-color: rgba(255,255,255,0.20);
                             -fx-background-radius: 20; -fx-padding: 5 14;">
                    <Label text="2" style="-fx-background-color: white;
                                          -fx-text-fill: #0c4a6e;
                                          -fx-background-radius: 50;
                                          -fx-min-width: 20; -fx-min-height: 20;
                                          -fx-alignment: center;
                                          -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label text="Get your questions"
                           style="-fx-text-fill: white; -fx-font-size: 12px;"/>
                </HBox>
                <Label text="›" style="-fx-text-fill: rgba(255,255,255,0.50); -fx-font-size: 14px;"/>
                <HBox spacing="6" alignment="CENTER"
                      style="-fx-background-color: rgba(255,255,255,0.20);
                             -fx-background-radius: 20; -fx-padding: 5 14;">
                    <Label text="3" style="-fx-background-color: white;
                                          -fx-text-fill: #0c4a6e;
                                          -fx-background-radius: 50;
                                          -fx-min-width: 20; -fx-min-height: 20;
                                          -fx-alignment: center;
                                          -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label text="Practice &amp; get feedback"
                           style="-fx-text-fill: white; -fx-font-size: 12px;"/>
                </HBox>
            </HBox>
        </VBox>
    </VBox>

    <!-- ═══════════════════════  CHAT AREA  ═══════════════════════════════ -->
    <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: #f0f6fc;
                       -fx-background: #f0f6fc;
                       -fx-border-color: transparent;"
                vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">

        <VBox fx:id="chatContainer" spacing="12"
              style="-fx-background-color: #f0f6fc; -fx-padding: 20 28;">
        </VBox>
    </ScrollPane>

    <!-- ═══════════════════════  INPUT BAR  ═══════════════════════════════ -->
    <VBox spacing="0"
          style="-fx-background-color: white;
                 -fx-border-color: #e0eaf3;
                 -fx-border-width: 1 0 0 0;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, -3);">

        <!-- Tip bar -->
        <HBox alignment="CENTER" spacing="6"
              style="-fx-background-color: #eff9fe;
                     -fx-padding: 7 24;
                     -fx-border-color: #bae6fd;
                     -fx-border-width: 0 0 1 0;">
            <Label text="💡"  style="-fx-font-size: 12px;"/>
            <Label text="Tip: Answer clearly and concisely. The AI will evaluate and ask the next question."
                   style="-fx-font-size: 11px; -fx-text-fill: #0369a1;"/>
        </HBox>

        <!-- Input row -->
        <HBox spacing="10" alignment="CENTER"
              style="-fx-padding: 14 20 14 20;">

            <!-- Avatar -->
            <StackPane style="-fx-background-color: linear-gradient(to bottom right, #0c4a6e, #0fafdd);
                              -fx-background-radius: 50;
                              -fx-min-width: 36; -fx-min-height: 36;
                              -fx-max-width: 36; -fx-max-height: 36;">
                <Label text="👤" style="-fx-font-size: 14px;"/>
            </StackPane>

            <!-- Text field -->
            <TextField fx:id="messageField"
                       promptText="Type your answer or a job title to start…"
                       HBox.hgrow="ALWAYS"
                       onAction="#handleSend"
                       style="-fx-background-color: #f0f6fc;
                              -fx-border-color: #bae6fd;
                              -fx-border-width: 1.5;
                              -fx-border-radius: 25;
                              -fx-background-radius: 25;
                              -fx-padding: 11 18;
                              -fx-font-size: 13px;
                              -fx-text-fill: #0f172a;
                              -fx-prompt-text-fill: #94a3b8;"/>

            <!-- Send button -->
            <Button text="Send  ➤"
                    onAction="#handleSend"
                    style="-fx-background-color: linear-gradient(to right, #0284c7, #0fafdd);
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 25;
                           -fx-padding: 11 22;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(2,132,199,0.35), 8, 0, 0, 3);"/>
        </HBox>
    </VBox>

</VBox>
