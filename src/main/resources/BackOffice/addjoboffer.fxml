<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="750.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.BackOffice.joboffer.addJobOfferController"
            style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #1a2980 0%, #26d0ce 100%);">
   <!-- Decorative elements (placed behind the card) -->
   <Circle fill="#ffffff15" radius="150.0" AnchorPane.leftAnchor="-20.0" AnchorPane.bottomAnchor="50.0" />
   <Circle fill="#ffffff10" radius="200.0" AnchorPane.rightAnchor="-20.0" AnchorPane.topAnchor="-20.0" />
   <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#ffffff08" height="250.0"
              AnchorPane.rightAnchor="50.0" AnchorPane.bottomAnchor="50.0" rotate="30.0"
              stroke="TRANSPARENT" width="250.0" />
   <children>
      <!-- Main content card - perfectly centered -->
      <VBox alignment="CENTER"
            AnchorPane.topAnchor="30.0"
            AnchorPane.bottomAnchor="30.0"
            AnchorPane.leftAnchor="30.0"
            AnchorPane.rightAnchor="30.0"
            spacing="20.0"
            style="-fx-background-color: white; -fx-background-radius: 24;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 25, 0, 0, 10);">

         <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
         </padding>

         <children>
            <!-- Header with icon and gradient text -->
            <VBox alignment="CENTER" spacing="8.0">
               <Label text="➕" style="-fx-font-size: 36px; -fx-text-fill: #1a2980;" />

               <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI', 'Arial';"
                      text="Add New Job Offer">
                  <textFill>
                     <LinearGradient endX="0.5" endY="0.0" startX="0.5" startY="1.0">
                        <stops>
                           <Stop color="#1a2980" offset="0.0" />
                           <Stop color="#26d0ce" offset="1.0" />
                        </stops>
                     </LinearGradient>
                  </textFill>
               </Label>

               <Label style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;
                                  -fx-font-family: 'Segoe UI', 'Arial';"
                      text="Fill in the job details below" />
            </VBox>

            <!-- Form fields -->
            <VBox spacing="18.0">
               <children>
                  <!-- Title field -->
                  <VBox spacing="4.0">
                     <Label style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #1e293b;"
                            text="Job Title" />
                     <TextField fx:id="titleField"
                                promptText="e.g. Senior Software Developer"
                                style="-fx-background-radius: 12; -fx-border-radius: 12;
                                              -fx-border-color: #e2e8f0; -fx-border-width: 1;
                                              -fx-background-color: white; -fx-padding: 12 15;
                                              -fx-font-size: 14px;" />
                  </VBox>

                  <!-- Description field -->
                  <VBox spacing="4.0">
                     <Label style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #1e293b;"
                            text="Description" />
                     <TextArea fx:id="descriptionField" prefHeight="120.0"
                               promptText="Describe the job position, responsibilities, and requirements..."
                               style="-fx-background-radius: 12; -fx-border-radius: 12;
                                             -fx-border-color: #e2e8f0; -fx-border-width: 1;
                                             -fx-background-color: white; -fx-font-size: 14px;
                                             -fx-padding: 12;" wrapText="true" />
                  </VBox>

                  <!-- Recruiter field -->
                  <VBox spacing="4.0">
                     <Label style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #1e293b;"
                            text="Recruiter id" />
                     <TextField fx:id="recruiterField"
                                promptText="Enter Recruiter ID"

                                style="-fx-background-radius: 12; -fx-border-radius: 12;
                                              -fx-border-color: #e2e8f0; -fx-border-width: 1;
                                              -fx-background-color: white; -fx-padding: 12 15;
                                              -fx-font-size: 14px;" />
                  </VBox>

                  <!-- Job Type field -->
                  <VBox spacing="4.0">
                     <Label style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #1e293b;"
                            text="Job Type" />
                     <ComboBox fx:id="typeField" promptText="Select job type"
                               style="-fx-background-radius: 12; -fx-border-radius: 12;
                                              -fx-border-color: #e2e8f0; -fx-border-width: 1;
                                              -fx-background-color: white; -fx-padding: 10;
                                              -fx-font-size: 14px;" maxWidth="Infinity" />
                  </VBox>


               </children>
            </VBox>

            <!-- Buttons section -->
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button fx:id="cancelButton"
                          onAction="#handleCancel"
                          text="Cancel"
                          style="-fx-background-color: white; -fx-text-fill: #64748b;
                                       -fx-border-color: #e2e8f0; -fx-border-width: 1.5;
                                       -fx-border-radius: 12; -fx-background-radius: 12;
                                       -fx-padding: 12 35; -fx-font-size: 14px;
                                       -fx-font-weight: bold; -fx-cursor: hand;" />

                  <Button onAction="#handleAddJobOffer"
                          text="Add Job Offer"
                          style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #1a2980 0%, #26d0ce 100%);
                                       -fx-text-fill: white; -fx-background-radius: 12;
                                       -fx-padding: 12 35; -fx-font-size: 14px;
                                       -fx-font-weight: bold; -fx-cursor: hand;">
                     <effect>
                        <DropShadow color="#1a298080" radius="10" spread="0.2" />
                     </effect>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>


   </children>
</AnchorPane>