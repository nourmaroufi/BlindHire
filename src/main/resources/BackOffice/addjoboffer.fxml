<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="500.0" prefWidth="660.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.BackOffice.joboffer.addJobOfferController"
            style="-fx-background-color: #0f172a;">

   <!-- Ambient glow blobs -->
   <Circle fill="#6366f1" radius="200" layoutX="580" layoutY="-40"
           opacity="0.13" mouseTransparent="true">
      <effect><GaussianBlur radius="90"/></effect>
   </Circle>
   <Circle fill="#06b6d4" radius="180" layoutX="-50" layoutY="680"
           opacity="0.10" mouseTransparent="true">
      <effect><GaussianBlur radius="80"/></effect>
   </Circle>

   <children>
      <!-- ═══ GLASS CARD ════════════════════════════════════════════════ -->
      <VBox fx:id="mainCard" alignment="TOP_CENTER" spacing="0"
            AnchorPane.topAnchor="20.0" AnchorPane.bottomAnchor="20.0"
            AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0"
            style="-fx-background-color: rgba(255,255,255,0.06);
                     -fx-background-radius: 22;
                     -fx-border-color: rgba(255,255,255,0.11); -fx-border-radius: 22; -fx-border-width: 1;">
         <effect>
            <DropShadow color="rgba(0,0,0,0.40)" radius="32" spread="0.04" offsetY="8"/>
         </effect>

         <!-- ══ STEP INDICATOR ═════════════════════════════════════════ -->
         <HBox alignment="CENTER_LEFT" spacing="0"
               style="-fx-background-color: rgba(255,255,255,0.04);
                         -fx-background-radius: 22 22 0 0;
                         -fx-padding: 14 24 14 24;
                         -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 0 0 1 0;">

            <!-- Step 1 -->
            <HBox spacing="9" alignment="CENTER_LEFT">
               <StackPane minWidth="28" minHeight="28" maxWidth="28" maxHeight="28">
                  <Circle fx:id="step1Circle" radius="14"
                          style="-fx-fill: linear-gradient(from 0% 0% to 100% 100%, #4338ca, #6366f1);"/>
                  <Label fx:id="step1Num" text="1"
                         style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 12;
                                      -fx-font-family: 'Segoe UI';"/>
               </StackPane>
               <VBox spacing="1">
                  <Label fx:id="step1Title" text="Job Details"
                         style="-fx-text-fill: #818cf8; -fx-font-weight: 800; -fx-font-size: 12;
                                      -fx-font-family: 'Segoe UI';"/>
                  <Label fx:id="step1Sub" text="Fill in the position info"
                         style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 10;
                                      -fx-font-family: 'Segoe UI';"/>
               </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" minHeight="2" maxHeight="2"
                    style="-fx-background-color: rgba(255,255,255,0.10);
                               -fx-background-radius: 2;">
               <HBox.margin><Insets left="14" right="14"/></HBox.margin>
            </Region>

            <!-- Step 2 -->
            <HBox spacing="9" alignment="CENTER_LEFT">
               <StackPane minWidth="28" minHeight="28" maxWidth="28" maxHeight="28">
                  <Circle fx:id="step2Circle" radius="14"
                          style="-fx-fill: rgba(255,255,255,0.07);
                                       -fx-stroke: rgba(255,255,255,0.20); -fx-stroke-width: 1.5;"/>
                  <Label fx:id="step2Num" text="2"
                         style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-weight: 800;
                                      -fx-font-size: 12; -fx-font-family: 'Segoe UI';"/>
               </StackPane>
               <VBox spacing="1">
                  <Label fx:id="step2Title" text="Quiz Setup"
                         style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-weight: 700;
                                      -fx-font-size: 12; -fx-font-family: 'Segoe UI';"/>
                  <Label fx:id="step2Sub" text="Add questions &amp; answers"
                         style="-fx-text-fill: rgba(255,255,255,0.22); -fx-font-size: 10;
                                      -fx-font-family: 'Segoe UI';"/>
               </VBox>
            </HBox>
         </HBox>

         <!-- ══ CONTENT SWAP AREA ══════════════════════════════════════ -->
         <StackPane VBox.vgrow="ALWAYS">

            <!-- ─── STEP 1: JOB FORM ──────────────────────────────── -->
            <VBox fx:id="step1Pane" spacing="0">

               <VBox spacing="14" style="-fx-padding: 22 28 0 28;">

                  <!-- Page title -->
                  <VBox alignment="CENTER" spacing="4">
                     <Label text="✦" style="-fx-font-size: 18; -fx-text-fill: #818cf8;"/>
                     <Label text="New Job Offer"
                            style="-fx-font-size: 20; -fx-font-weight: 800;
                                          -fx-font-family: 'Segoe UI'; -fx-text-fill: white;"/>
                     <Label text="Complete both steps to publish this position"
                            style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.35);
                                          -fx-font-family: 'Segoe UI';"/>
                  </VBox>

                  <Region prefHeight="1" maxHeight="1"
                          style="-fx-background-color: rgba(255,255,255,0.08);"/>

                  <!-- Form fields -->
                  <VBox spacing="13">

                     <HBox spacing="14">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                           <Label text="JOB TITLE"
                                  style="-fx-font-size: 10; -fx-font-weight: 800;
                                                  -fx-text-fill: rgba(255,255,255,0.50);
                                                  -fx-font-family: 'Segoe UI';"/>
                           <TextField fx:id="titleField" promptText="e.g. Senior Software Developer"
                                      style="-fx-background-color: rgba(255,255,255,0.07);
                                                      -fx-background-radius: 10; -fx-border-radius: 10;
                                                      -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1;
                                                      -fx-padding: 9 12; -fx-font-size: 12;
                                                      -fx-text-fill: white;
                                                      -fx-prompt-text-fill: rgba(255,255,255,0.25);
                                                      -fx-font-family: 'Segoe UI';"/>
                        </VBox>
                        <VBox spacing="4" prefWidth="150">
                           <Label text="TYPE"
                                  style="-fx-font-size: 10; -fx-font-weight: 800;
                                                  -fx-text-fill: rgba(255,255,255,0.50);
                                                  -fx-font-family: 'Segoe UI';"/>
                           <ComboBox fx:id="typeField" promptText="Select type" maxWidth="Infinity"
                                     style="-fx-background-color: rgba(255,255,255,0.07);
                                                     -fx-background-radius: 10; -fx-border-radius: 10;
                                                     -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1;
                                                     -fx-font-size: 12; -fx-font-family: 'Segoe UI';"/>
                        </VBox>
                     </HBox>

                     <VBox spacing="4">
                        <Label text="DESCRIPTION"
                               style="-fx-font-size: 10; -fx-font-weight: 800;
                                              -fx-text-fill: rgba(255,255,255,0.50);
                                              -fx-font-family: 'Segoe UI';"/>
                        <TextArea fx:id="descriptionField" prefHeight="80"
                                  promptText="Describe the role, responsibilities, and requirements..."
                                  wrapText="true"
                                  style="-fx-background-color: rgba(255,255,255,0.07);
                                                 -fx-background-radius: 10; -fx-border-radius: 10;
                                                 -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1;
                                                 -fx-font-size: 12; -fx-font-family: 'Segoe UI';
                                                 -fx-padding: 8 12; -fx-text-fill: white;
                                                 -fx-prompt-text-fill: rgba(255,255,255,0.25);
                                                 -fx-control-inner-background: transparent;"/>
                     </VBox>

                     <VBox spacing="4">
                        <Label text="REQUIRED SKILLS"
                               style="-fx-font-size: 10; -fx-font-weight: 800;
                                              -fx-text-fill: rgba(255,255,255,0.50);
                                              -fx-font-family: 'Segoe UI';"/>
                        <TextField fx:id="skillsField" promptText="e.g. Java, Python, SQL, Communication"
                                   style="-fx-background-color: rgba(255,255,255,0.07);
                                                  -fx-background-radius: 10; -fx-border-radius: 10;
                                                  -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1;
                                                  -fx-padding: 9 12; -fx-font-size: 12;
                                                  -fx-text-fill: white;
                                                  -fx-prompt-text-fill: rgba(255,255,255,0.25);
                                                  -fx-font-family: 'Segoe UI';"/>
                        <Label text="💡  These will appear as quiz context in Step 2"
                               style="-fx-font-size: 10; -fx-text-fill: #818cf8;
                                              -fx-font-style: italic; -fx-font-family: 'Segoe UI';"/>
                     </VBox>

                     <HBox spacing="14">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                           <Label text="SALARY (TND / MONTH)"
                                  style="-fx-font-size: 10; -fx-font-weight: 800;
                                                  -fx-text-fill: rgba(255,255,255,0.50);
                                                  -fx-font-family: 'Segoe UI';"/>
                           <TextField fx:id="salaryField" promptText="e.g. 2500  (optional)"
                                      style="-fx-background-color: rgba(255,255,255,0.07);
                                                      -fx-background-radius: 10; -fx-border-radius: 10;
                                                      -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1;
                                                      -fx-padding: 9 12; -fx-font-size: 12;
                                                      -fx-text-fill: white;
                                                      -fx-prompt-text-fill: rgba(255,255,255,0.25);
                                                      -fx-font-family: 'Segoe UI';"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                           <Label text="POSTED BY"
                                  style="-fx-font-size: 10; -fx-font-weight: 800;
                                                  -fx-text-fill: rgba(255,255,255,0.50);
                                                  -fx-font-family: 'Segoe UI';"/>
                           <Label fx:id="recruiterInfoLabel" text="(logged-in user)"
                                  style="-fx-background-color: rgba(99,102,241,0.15);
                                                  -fx-background-radius: 10; -fx-border-radius: 10;
                                                  -fx-border-color: rgba(99,102,241,0.30); -fx-border-width: 1;
                                                  -fx-padding: 9 12; -fx-font-size: 12;
                                                  -fx-text-fill: #818cf8; -fx-font-family: 'Segoe UI';"/>
                        </VBox>
                     </HBox>
                  </VBox>
               </VBox>

               <Region VBox.vgrow="ALWAYS"/>

               <!-- Step 1 footer -->
               <HBox alignment="CENTER_RIGHT" spacing="12"
                     style="-fx-padding: 14 28 20 28;
                                 -fx-background-color: rgba(255,255,255,0.03);
                                 -fx-background-radius: 0 0 22 22;
                                 -fx-border-color: rgba(255,255,255,0.07); -fx-border-width: 1 0 0 0;">
                  <Button fx:id="cancelButton" onAction="#handleCancel" text="Cancel"
                          style="-fx-background-color: rgba(255,255,255,0.07);
                                       -fx-text-fill: rgba(255,255,255,0.65);
                                       -fx-border-color: rgba(255,255,255,0.12); -fx-border-width: 1.5;
                                       -fx-border-radius: 10; -fx-background-radius: 10;
                                       -fx-padding: 9 22; -fx-font-size: 12; -fx-font-weight: 700;
                                       -fx-cursor: hand; -fx-font-family: 'Segoe UI';"/>
                  <Button onAction="#handleAddJobOffer" text="Save &amp; Build Quiz  →"
                          style="-fx-background-color: linear-gradient(to right, #4338ca, #6366f1);
                                       -fx-text-fill: white; -fx-background-radius: 10;
                                       -fx-padding: 9 24; -fx-font-size: 12; -fx-font-weight: 800;
                                       -fx-cursor: hand; -fx-font-family: 'Segoe UI';
                                       -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.50), 10, 0.1, 0, 3);"/>
               </HBox>
            </VBox>

            <!-- ─── STEP 2: quiz panel injected here by controller ─── -->
            <VBox fx:id="step2Pane" visible="false" managed="false" VBox.vgrow="ALWAYS"/>

         </StackPane>
      </VBox>
   </children>
</AnchorPane>
