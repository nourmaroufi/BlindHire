<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<VBox spacing="0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controller.ChatController"
      stylesheets="/chat.css">   <!-- external CSS file -->

    <!-- Chat Header -->
    <HBox styleClass="chat-header" alignment="CENTER_LEFT" spacing="10">
        <padding>
            <Insets top="10" right="15" bottom="10" left="15"/>
        </padding>
        <ImageView fx:id="profileImage" fitHeight="40" fitWidth="40" styleClass="avatar"/>
        <VBox spacing="2">

            <Label fx:id="contactStatus" text="Online" styleClass="contact-status"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button styleClass="header-button" text="⋯"/>   <!-- options menu -->
    </HBox>

    <!-- Message List -->
    <ListView fx:id="messageListView" VBox.vgrow="ALWAYS">
        <!-- We'll set a custom cell factory in the controller -->
    </ListView>

    <!-- Message Input Area -->
    <HBox styleClass="input-area" spacing="10" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10" right="15" bottom="10" left="15"/>
        </padding>
        <Button styleClass="emoji-button" text="😊" visible="false" managed="false"/> <!-- optional -->
        <TextField fx:id="messageField" promptText="Type a message..." HBox.hgrow="ALWAYS"/>
        <Button styleClass="attach-button" text="📎" visible="false" managed="false"/> <!-- optional -->
        <Button styleClass="send-button" text="Send" onAction="#handleSend"/>
    </HBox>

</VBox>