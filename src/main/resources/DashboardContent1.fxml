<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.FrontOffice.Dashboard1Controller"
      spacing="0"
      style="-fx-background-color: transparent;">

    <!-- HEADER -->
    <HBox alignment="CENTER_RIGHT"
          style="-fx-background-color: transparent; -fx-padding: 20 40;">

        <Region HBox.hgrow="ALWAYS"/>

        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button text="🔔"
                    style="-fx-background-color: #f1f5f9; -fx-font-size: 18px; -fx-background-radius: 50; -fx-padding: 10;"/>
            <Button text="✉️"
                    style="-fx-background-color: #f1f5f9; -fx-font-size: 18px; -fx-background-radius: 50; -fx-padding: 10;"/>
        </HBox>
    </HBox>

    <!-- HERO SECTION -->
    <HBox spacing="50"
          style="-fx-padding: 20 60 30 60;">

        <!-- LEFT SIDE -->
        <VBox spacing="25" maxWidth="650">
            <HBox spacing="15">
                <Label text="Find Your Dream Job"
                       style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label text="✨" style="-fx-font-size: 42px;"/>
            </HBox>

            <Label text="Connect with top companies and opportunities that match your skills and aspirations."
                   wrapText="true"
                   style="-fx-font-size: 16px; -fx-text-fill: #475569;"/>

            <Button text="Browse All Jobs →"
                    onAction="#handleViewAllJobs"
                    style="-fx-background-color: linear-gradient(to right, #4f46e5, #3b82f6);
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 16px;
                           -fx-background-radius: 30;
                           -fx-padding: 15 35;"/>
        </VBox>

        <!-- RIGHT SIDE ILLUSTRATION -->
        <StackPane prefWidth="450" prefHeight="350">

            <Circle radius="160"
                    fill="linear-gradient(to bottom right, #4f46e515, #3b82f615)"/>

            <VBox alignment="CENTER" spacing="15">
                <Label text="🚀" style="-fx-font-size: 70px;"/>

                <Rectangle width="220" height="40" arcWidth="15" arcHeight="15"
                           style="-fx-fill: white; -fx-stroke: #e2e8f0;"/>

                <Rectangle width="200" height="40" arcWidth="15" arcHeight="15"
                           style="-fx-fill: white; -fx-stroke: #e2e8f0;"/>

                <Rectangle width="180" height="40" arcWidth="15" arcHeight="15"
                           style="-fx-fill: white; -fx-stroke: #e2e8f0;"/>
            </VBox>
        </StackPane>

    </HBox>

</VBox>