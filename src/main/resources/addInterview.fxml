<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controller.AddInterviewController"
      spacing="0" alignment="TOP_CENTER"
      prefWidth="680"
      style="-fx-background-color: #f4f6fb;">

    <!-- Header Banner -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #1a2980;
                 -fx-padding: 20 30;">
        <Label text="📅" style="-fx-font-size:22px;"/>
        <VBox spacing="2">
            <Label text="Schedule an Interview"
                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>
            <Label text="Fill in the details below to book a new interview"
                   style="-fx-font-size:12px; -fx-text-fill:#b3c6e0;"/>
        </VBox>
    </HBox>

    <!-- Form Card -->
    <VBox spacing="0"
          style="-fx-background-color:white;
                 -fx-background-radius: 0 0 16 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
        <padding>
            <Insets top="25" right="30" bottom="25" left="30"/>
        </padding>

        <GridPane hgap="15" vgap="18" prefWidth="580">
            <columnConstraints>
                <ColumnConstraints prefWidth="130" minWidth="130"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Candidate -->
            <Label text="Candidate" GridPane.rowIndex="0" GridPane.columnIndex="0"
                   style="-fx-font-weight:bold; -fx-text-fill:#444; -fx-font-size:13px;"/>
            <ComboBox fx:id="candidateComboBox" maxWidth="Infinity"
                      GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"/>

            <!-- Date -->
            <Label text="Date" GridPane.rowIndex="1" GridPane.columnIndex="0"
                   style="-fx-font-weight:bold; -fx-text-fill:#444; -fx-font-size:13px;"/>
            <DatePicker fx:id="datePicker" maxWidth="Infinity"
                        GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"/>

            <!-- Time -->
            <Label text="Time" GridPane.rowIndex="2" GridPane.columnIndex="0"
                   style="-fx-font-weight:bold; -fx-text-fill:#444; -fx-font-size:13px;"/>
            <ComboBox fx:id="timeComboBox" maxWidth="Infinity"
                      GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"/>

            <!-- Type -->
            <Label text="Interview Type" GridPane.rowIndex="3" GridPane.columnIndex="0"
                   style="-fx-font-weight:bold; -fx-text-fill:#444; -fx-font-size:13px;"/>
            <ComboBox fx:id="typeComboBox" maxWidth="Infinity"
                      GridPane.rowIndex="3" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"/>

            <!-- Job Offer -->
            <Label text="Job Offer" GridPane.rowIndex="4" GridPane.columnIndex="0"
                   style="-fx-font-weight:bold; -fx-text-fill:#444; -fx-font-size:13px;"/>
            <TextField fx:id="jobOfferField" promptText="e.g. Java Developer"
                       maxWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1"
                       GridPane.hgrow="ALWAYS"/>

            <!-- Interviewer -->
            <Label text="Interviewer" GridPane.rowIndex="5" GridPane.columnIndex="0"
                   style="-fx-font-weight:bold; -fx-text-fill:#444; -fx-font-size:13px;"/>
            <TextField fx:id="interviewerField" promptText="e.g. John Smith"
                       maxWidth="Infinity" GridPane.rowIndex="5" GridPane.columnIndex="1"
                       GridPane.hgrow="ALWAYS"/>

            <!-- Location Row (In Person only) -->
            <Label fx:id="locationLabel" text="Address" GridPane.rowIndex="6" GridPane.columnIndex="0"
                   style="-fx-font-weight:bold; -fx-text-fill:#444; -fx-font-size:13px;"/>
            <HBox GridPane.rowIndex="6" GridPane.columnIndex="1" spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="locationField" promptText="Type an address to search..."
                           HBox.hgrow="ALWAYS"/>
                <Button fx:id="searchMapBtn" text="🔍 Search"
                        onAction="#handleSearchLocation"
                        style="-fx-background-color:#1a2980; -fx-text-fill:white;
                               -fx-background-radius:8; -fx-padding: 7 14; -fx-font-size:12px;"/>
            </HBox>

            <!-- Map Preview -->
            <Label fx:id="mapLabel" text="Map Preview" GridPane.rowIndex="7" GridPane.columnIndex="0"
                   style="-fx-font-weight:bold; -fx-text-fill:#444; -fx-font-size:13px;"/>
            <WebView fx:id="mapView" GridPane.rowIndex="7" GridPane.columnIndex="1"
                     prefHeight="300" maxWidth="Infinity"/>
        </GridPane>
    </VBox>

    <!-- Buttons -->
    <HBox spacing="15" alignment="CENTER" style="-fx-padding: 20 30;">
        <Button text="✅ Add Interview" fx:id="addButton" onAction="#handleAddInterview"
                prefWidth="160"
                style="-fx-background-color:#1a2980; -fx-text-fill:white;
                       -fx-background-radius:10; -fx-padding: 10 20;
                       -fx-font-size:13px; -fx-font-weight:bold; -fx-cursor:hand;"/>
        <Button text="✖ Cancel" fx:id="cancelButton" onAction="#handleCancel"
                prefWidth="120"
                style="-fx-background-color:#f0f4f8; -fx-text-fill:#1a2980;
                       -fx-background-radius:10; -fx-padding: 10 20; -fx-font-size:13px;
                       -fx-border-color:#1a2980; -fx-border-radius:10; -fx-cursor:hand;"/>
    </HBox>

</VBox>
